#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
args=(--install-deps)

while [ "$#" -gt 0 ]; do
  case "$1" in
    --check-only)
      args+=(--dry-run)
      ;;
    -h|--help)
      cat <<'HELP'
Usage: script/bootstrap [--yes] [--check-only] [--with-oh-my-zsh] [install options]

Compatibility wrapper for script/install --install-deps.
Use script/install directly for new setup flows.

Common flags:
  --yes                         non-interactive package/PATH setup
  --check-only                  compatibility alias for --dry-run
  --with-oh-my-zsh              explicitly opt into Oh My Zsh install
  --shell-preset PRESET         configure curated shell add-ons: migration
  --zsh-theme THEME             zsh theme: robbyrussell or powerlevel10k
  --zsh-plugins LIST            comma-separated allowlisted zsh plugins
  --skip-docker                 do not install Docker host packages
  --docker-source SOURCE        Docker source: official, distro, or auto
  --bin-dir DIR                 write shims to DIR
  --install-dir DIR             clone/update the managed checkout at DIR
  --repo URL                    Git repository URL
  --branch BRANCH               Git branch
HELP
      exit 0
      ;;
    *)
      args+=("$1")
      ;;
  esac
  shift
done

exec "$script_dir/install" "${args[@]}"
