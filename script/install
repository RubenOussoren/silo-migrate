#!/usr/bin/env bash
set -euo pipefail

yes_mode=0
install_deps=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --yes) yes_mode=1; install_deps=1 ;;
    --install-deps) install_deps=1 ;;
    -h|--help)
      cat <<'HELP'
Usage: script/install [--yes] [--install-deps]

Installs silo-migrate from a Git-managed checkout and writes global shims.
On Debian/Ubuntu, --install-deps offers to install missing host packages first.
--yes installs missing Debian/Ubuntu packages without prompting.
HELP
      exit 0
      ;;
    *) printf 'Error: unknown option %s\n' "$1" >&2; exit 1 ;;
  esac
  shift
done

repo="${SILO_MIGRATE_REPO:-git@github.com:RubenOussoren/silo-migrate.git}"
branch="${SILO_MIGRATE_BRANCH:-main}"
home_dir="${HOME:?HOME is required}"
data_home="${XDG_DATA_HOME:-$home_dir/.local/share}"
install_dir="${SILO_MIGRATE_INSTALL_DIR:-$data_home/silo-migrate/source}"
bin_dir="${SILO_MIGRATE_BIN_DIR:-$home_dir/.local/bin}"
debian_packages=(git ruby ruby-dev build-essential zlib1g-dev libsqlite3-dev zsh docker.io docker-compose-plugin)
sudocmd=()

log() {
  printf '%s\n' "$*"
}

fail() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

warn() {
  printf '[WARN] %s\n' "$*" >&2
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

confirm() {
  local prompt="$1"
  [ "$yes_mode" -eq 1 ] && return 0
  [ -t 0 ] || return 1
  local answer
  read -r -p "$prompt [y/N] " answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

setup_sudo() {
  if [ "$(id -u)" -eq 0 ]; then
    sudocmd=()
  elif command_exists sudo; then
    sudocmd=(sudo)
  else
    return 1
  fi
}

ruby_ready() {
  command_exists ruby && ruby -e 'exit(Gem::Version.new(RUBY_VERSION) >= Gem::Version.new("3.1.0"))' >/dev/null 2>&1
}

print_debian_commands() {
  cat <<COMMANDS
Run these commands, then re-run script/install:

  apt-get update
  apt-get install -y ${debian_packages[*]}
  gem install bundler
COMMANDS
}

install_debian_deps() {
  command_exists apt-get || return 1
  setup_sudo || return 1

  log "Installing Debian/Ubuntu dependencies..."
  "${sudocmd[@]}" apt-get update
  "${sudocmd[@]}" apt-get install -y "${debian_packages[@]}"
}

ensure_host_dependencies() {
  if command_exists git && ruby_ready; then
    return
  fi

  if command_exists apt-get; then
    if [ "$install_deps" -eq 1 ] || confirm "Install missing Debian/Ubuntu dependencies now?"; then
      install_debian_deps || fail "Could not install Debian/Ubuntu dependencies."
      return
    fi

    print_debian_commands
    exit 1
  fi

  fail "git and Ruby >= 3.1 are required. Run script/bootstrap or install them manually first."
}

ensure_command() {
  command_exists "$1" || fail "$1 is required. Run script/bootstrap or install it manually first."
}

write_shim() {
  local name="$1"
  local shim="$bin_dir/$name"
  local escaped_dir
  escaped_dir="$(printf '%q' "$install_dir")"

  cat > "$shim" <<SHIM
#!/usr/bin/env bash
set -euo pipefail
cd $escaped_dir
exec bundle exec ruby bin/$name "\$@"
SHIM
  chmod +x "$shim"
}

ensure_host_dependencies
ensure_command git
ensure_command ruby

if ! ruby_ready; then
  fail "Ruby >= 3.1 is required. Run script/bootstrap or install Ruby with rbenv, asdf, or Homebrew."
fi

if ! command_exists bundle; then
  log "Bundler is missing; installing it with gem..."
  gem install bundler
fi

mkdir -p "$(dirname "$install_dir")"
if [ -d "$install_dir/.git" ]; then
  log "Updating existing checkout at $install_dir..."
  git -C "$install_dir" fetch origin "$branch"
  git -C "$install_dir" checkout "$branch"
  git -C "$install_dir" pull --ff-only origin "$branch"
elif [ -e "$install_dir" ]; then
  fail "$install_dir exists but is not a Git checkout. Move it away or set SILO_MIGRATE_INSTALL_DIR."
else
  log "Cloning $repo into $install_dir..."
  git clone --branch "$branch" "$repo" "$install_dir"
fi

log "Installing Ruby gems..."
(cd "$install_dir" && bundle install)

mkdir -p "$bin_dir"
write_shim silo-migrate
write_shim migration-tool
write_shim xml-to-sql

log "[OK] Installed silo-migrate shims in $bin_dir"
if [[ ":$PATH:" != *":$bin_dir:"* ]]; then
  log "[WARN] $bin_dir is not on PATH."
  log "       Add this to your shell profile: export PATH=\"$bin_dir:\$PATH\""
fi
log "Run: silo-migrate doctor"
