#!/usr/bin/env bash
set -euo pipefail

yes_mode=0
install_deps=0
with_oh_my_zsh=0
skip_docker=0
dry_run=0
docker_source="auto"
repo=""
branch=""
install_dir=""
bin_dir=""
brew_ruby_bin=""
sudocmd=()

usage() {
  cat <<'HELP'
Usage: script/install [options]

Installs silo-migrate from a Git-managed checkout and writes global shims.
This is the primary installer for macOS, Debian/Ubuntu, and Fedora/RHEL hosts.

Options:
  --yes                         non-interactive install; also enables --install-deps
  --install-deps                install missing host dependencies first
  --with-oh-my-zsh              install Oh My Zsh when dependencies are installed
  --skip-docker                 do not install Docker host packages
  --docker-source SOURCE        Docker source: official, distro, or auto (default: auto)
  --bin-dir DIR                 write shims to DIR
  --install-dir DIR             clone/update the managed checkout at DIR
  --repo URL                    Git repository URL (default: HTTPS GitHub repo)
  --branch BRANCH               Git branch (default: main)
  --dry-run                     print commands without running them
  -h, --help                    show this help

Environment overrides are still supported:
  SILO_MIGRATE_REPO, SILO_MIGRATE_BRANCH, SILO_MIGRATE_INSTALL_DIR,
  SILO_MIGRATE_BIN_DIR, XDG_DATA_HOME
HELP
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf '[WARN] %s\n' "$*" >&2
}

fail() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

confirm() {
  local prompt="$1"
  [ "$yes_mode" -eq 1 ] && return 0
  [ -t 0 ] || return 1
  local answer
  read -r -p "$prompt [y/N] " answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

shell_quote() {
  printf '%q' "$1"
}

print_command() {
  printf '+ '
  printf '%q ' "$@"
  printf '\n'
}

run_cmd() {
  if [ "$dry_run" -eq 1 ]; then
    print_command "$@"
    return 0
  fi
  "$@"
}

run_root_cmd() {
  if [ "$dry_run" -eq 1 ]; then
    if [ "${#sudocmd[@]}" -gt 0 ]; then
      printf '+ '
      printf '%q ' "${sudocmd[@]}"
      printf '%q ' "$@"
      printf '\n'
      return 0
    fi
    print_command "$@"
    return 0
  fi
  "${sudocmd[@]}" "$@"
}

run_root_shell() {
  local command="$1"
  if [ "$dry_run" -eq 1 ]; then
    if [ "${#sudocmd[@]}" -gt 0 ]; then
      printf '+ '
      printf '%q ' "${sudocmd[@]}"
      printf 'sh -c %q\n' "$command"
    else
      printf '+ sh -c %q\n' "$command"
    fi
    return 0
  fi
  "${sudocmd[@]}" sh -c "$command"
}

run_shell() {
  local command="$1"
  if [ "$dry_run" -eq 1 ]; then
    printf '+ sh -c %q\n' "$command"
    return 0
  fi
  sh -c "$command"
}

setup_sudo() {
  if [ "$(id -u)" -eq 0 ]; then
    sudocmd=()
  elif command_exists sudo; then
    sudocmd=(sudo)
  elif [ "$dry_run" -eq 1 ]; then
    sudocmd=(sudo)
  else
    return 1
  fi
}

detect_os_id() {
  local key="$1"
  if [ -r /etc/os-release ]; then
    . /etc/os-release
    case "$key" in
      id) printf '%s' "${ID:-}" ;;
      version_codename) printf '%s' "${VERSION_CODENAME:-}" ;;
      version_id) printf '%s' "${VERSION_ID:-}" ;;
      id_like) printf '%s' "${ID_LIKE:-}" ;;
    esac
  fi
}

ruby_ready() {
  command_exists ruby && ruby -e 'exit(Gem::Version.new(RUBY_VERSION) >= Gem::Version.new("3.1.0"))' >/dev/null 2>&1
}

prefer_homebrew_ruby() {
  command_exists brew || return 0
  local prefix
  prefix="$(brew --prefix ruby 2>/dev/null || true)"
  [ -n "$prefix" ] || return 0
  [ -x "$prefix/bin/ruby" ] || return 0
  brew_ruby_bin="$prefix/bin"
  export PATH="$brew_ruby_bin:$PATH"
}

default_bin_dir() {
  if [ "$(id -u)" -eq 0 ]; then
    printf '%s\n' "/usr/local/bin"
  else
    printf '%s\n' "${HOME:?HOME is required}/.local/bin"
  fi
}

default_install_dir() {
  local home_dir="${HOME:?HOME is required}"
  local data_home="${XDG_DATA_HOME:-$home_dir/.local/share}"
  printf '%s\n' "$data_home/silo-migrate/source"
}

parse_value_option() {
  local current="$1"
  local next="${2:-}"
  if [[ "$current" == *=* ]]; then
    printf '%s\n' "${current#*=}"
  else
    [ -n "$next" ] || fail "$current requires a value"
    printf '%s\n' "$next"
  fi
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --yes) yes_mode=1; install_deps=1 ;;
    --install-deps) install_deps=1 ;;
    --with-oh-my-zsh) with_oh_my_zsh=1 ;;
    --skip-docker) skip_docker=1 ;;
    --dry-run|--check-only) dry_run=1 ;;
    --docker-source|--docker-source=*)
      docker_source="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    --bin-dir|--bin-dir=*)
      bin_dir="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    --install-dir|--install-dir=*)
      install_dir="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    --repo|--repo=*)
      repo="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    --branch|--branch=*)
      branch="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *) fail "unknown option $1" ;;
  esac
  shift
done

case "$docker_source" in
  auto|official|distro) ;;
  *) fail "--docker-source must be official, distro, or auto" ;;
esac

repo="${repo:-${SILO_MIGRATE_REPO:-https://github.com/RubenOussoren/silo-migrate.git}}"
branch="${branch:-${SILO_MIGRATE_BRANCH:-main}}"
install_dir="${install_dir:-${SILO_MIGRATE_INSTALL_DIR:-$(default_install_dir)}}"
bin_dir="${bin_dir:-${SILO_MIGRATE_BIN_DIR:-$(default_bin_dir)}}"

install_homebrew() {
  if command_exists brew; then
    return
  fi

  if ! confirm "Install Homebrew using the official installer?"; then
    warn "Homebrew is missing. Install it from https://brew.sh/ or install git, Ruby >= 3.1, and Docker manually."
    return
  fi

  command_exists curl || fail "curl is required to install Homebrew."
  run_shell '/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'

  for brew_path in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [ -x "$brew_path" ]; then
      eval "$("$brew_path" shellenv)"
      return
    fi
  done
}

install_macos_deps() {
  install_homebrew
  command_exists brew || return 0

  local formulas=()
  command_exists git || formulas+=(git)
  ruby_ready || formulas+=(ruby)
  command_exists zsh || formulas+=(zsh)

  if [ "${#formulas[@]}" -gt 0 ]; then
    log "Installing Homebrew packages: ${formulas[*]}"
    run_cmd brew install "${formulas[@]}"
  fi

  if [ "$skip_docker" -eq 0 ] && ! command_exists docker; then
    if confirm "Install Docker Desktop with Homebrew cask?"; then
      run_cmd brew install --cask docker
      warn "Open Docker Desktop once after installation so the daemon starts."
    else
      warn "Docker is missing. Install Docker Desktop before running migration containers."
    fi
  fi

  prefer_homebrew_ruby
}

docker_conflicts_installed() {
  command_exists dpkg || return 1
  local pkg
  for pkg in docker.io docker-doc docker-compose podman-docker containerd runc; do
    if dpkg -s "$pkg" >/dev/null 2>&1; then
      return 0
    fi
  done
  return 1
}

install_apt_base_packages() {
  local packages=(git ruby ruby-dev build-essential zlib1g-dev libsqlite3-dev zsh curl ca-certificates gnupg)
  log "Installing Debian/Ubuntu base packages: ${packages[*]}"
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before --install-deps."
  run_root_cmd apt-get update
  run_root_cmd apt-get install -y "${packages[@]}"
}

install_apt_distro_docker() {
  local packages=(docker.io docker-compose-plugin)
  log "Installing Debian/Ubuntu distro Docker packages: ${packages[*]}"
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before installing Docker."
  run_root_cmd apt-get install -y "${packages[@]}"
}

install_apt_official_docker() {
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before installing Docker."

  local id codename
  id="$(detect_os_id id)"
  codename="$(detect_os_id version_codename)"
  if [[ "$id" != "debian" && "$id" != "ubuntu" ]]; then
    warn "Docker's apt repository supports Debian/Ubuntu here; falling back to distro packages."
    install_apt_distro_docker
    return
  fi
  [ -n "$codename" ] || fail "Could not detect Debian/Ubuntu codename for Docker's official apt repository."

  if docker_conflicts_installed; then
    if confirm "Remove conflicting distro Docker packages before installing Docker Engine from Docker's apt repository?"; then
      run_root_cmd apt-get remove -y docker.io docker-doc docker-compose podman-docker containerd runc
    else
      warn "Skipping official Docker repository because conflicting packages are installed."
      return
    fi
  fi

  log "Installing Docker Engine from Docker's official apt repository..."
  run_root_cmd install -m 0755 -d /etc/apt/keyrings
  run_root_shell "curl -fsSL https://download.docker.com/linux/$id/gpg -o /etc/apt/keyrings/docker.asc"
  run_root_cmd chmod a+r /etc/apt/keyrings/docker.asc
  run_root_shell "echo \"deb [arch=\$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/$id $codename stable\" > /etc/apt/sources.list.d/docker.list"
  run_root_cmd apt-get update
  run_root_cmd apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
}

install_apt_packages() {
  install_apt_base_packages
  [ "$skip_docker" -eq 1 ] && return

  if command_exists docker; then
    return
  fi

  case "$docker_source" in
    distro) install_apt_distro_docker ;;
    official|auto) install_apt_official_docker ;;
  esac
}

install_dnf_base_packages() {
  local packages=(git ruby ruby-devel gcc gcc-c++ make zlib-devel sqlite-devel zsh curl ca-certificates)
  log "Installing Fedora/RHEL base packages: ${packages[*]}"
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before --install-deps."
  run_root_cmd dnf install -y "${packages[@]}"
}

install_dnf_distro_docker() {
  local packages=(docker docker-compose-plugin)
  log "Installing distro Docker packages with dnf: ${packages[*]}"
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before installing Docker."
  run_root_cmd dnf install -y "${packages[@]}"
}

install_dnf_official_docker() {
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before installing Docker."

  local id id_like repo_os
  id="$(detect_os_id id)"
  id_like="$(detect_os_id id_like)"
  case " $id $id_like " in
    *" fedora "*) repo_os="fedora" ;;
    *" rhel "*|*" centos "*|*" rocky "*|*" almalinux "*) repo_os="centos" ;;
    *)
      warn "Docker's dnf repository is not configured for this distribution. Install Docker Engine manually from https://docs.docker.com/engine/install/."
      return
      ;;
  esac

  log "Installing Docker Engine from Docker's official dnf repository..."
  run_root_cmd dnf install -y dnf-plugins-core
  run_root_cmd dnf config-manager --add-repo "https://download.docker.com/linux/$repo_os/docker-ce.repo"
  run_root_cmd dnf install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
}

install_dnf_packages() {
  install_dnf_base_packages
  [ "$skip_docker" -eq 1 ] && return

  if command_exists docker; then
    return
  fi

  case "$docker_source" in
    distro) install_dnf_distro_docker ;;
    official|auto) install_dnf_official_docker ;;
  esac
}

enable_docker_service() {
  [ "$skip_docker" -eq 0 ] || return
  command_exists systemctl || return
  command_exists docker || [ "$dry_run" -eq 1 ] || return

  if confirm "Enable and start the Docker service?"; then
    setup_sudo || fail "sudo is missing. Re-run as root or start Docker manually."
    run_root_cmd systemctl enable --now docker
  else
    warn "Start Docker manually before running migration containers."
  fi
}

install_linux_deps() {
  if command_exists apt-get; then
    install_apt_packages
  elif command_exists dnf; then
    install_dnf_packages
  else
    warn "Unsupported Linux package manager. Install git, Ruby >= 3.1, Bundler, Docker Compose v2, and zsh manually."
  fi
  enable_docker_service
}

install_host_dependencies() {
  case "$(uname -s)" in
    Darwin) install_macos_deps ;;
    Linux) install_linux_deps ;;
    *) warn "Unsupported OS. Install git, Ruby >= 3.1, Bundler, Docker Compose v2, and zsh manually." ;;
  esac
}

ensure_host_dependencies() {
  if [ "$install_deps" -eq 1 ]; then
    install_host_dependencies
  elif ! command_exists git || ! ruby_ready; then
    if confirm "Install missing host dependencies now?"; then
      install_host_dependencies
    else
      fail "git and Ruby >= 3.1 are required. Re-run with --install-deps or install them manually."
    fi
  fi
}

install_bundler() {
  if [ "$dry_run" -eq 1 ] && [ "$install_deps" -eq 1 ]; then
    log "[dry-run] gem install bundler if missing"
    return
  fi

  command_exists bundle && return

  log "Installing Bundler..."
  run_cmd gem install bundler
}

install_oh_my_zsh() {
  [ "$install_deps" -eq 1 ] || return
  [ -d "${HOME:?HOME is required}/.oh-my-zsh" ] && return

  if [ "$with_oh_my_zsh" -ne 1 ] && [ "$yes_mode" -eq 1 ]; then
    log "Skipping Oh My Zsh; pass --with-oh-my-zsh to install it non-interactively."
    return
  fi

  if [ "$with_oh_my_zsh" -eq 1 ] || confirm "Install Oh My Zsh?"; then
    if ! command_exists curl && { [ "$dry_run" -eq 0 ] || [ "$install_deps" -eq 0 ]; }; then
      fail "curl is required to install Oh My Zsh."
    fi
    run_shell 'RUNZSH=no CHSH=no sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended'
  fi
}

shell_profile_path() {
  case "${SHELL:-}" in
    */bash) printf '%s\n' "${HOME:?HOME is required}/.bashrc" ;;
    *) printf '%s\n' "${HOME:?HOME is required}/.zshrc" ;;
  esac
}

ensure_shell_path() {
  local profile marker_begin marker_end path_prefix shellenv_line
  profile="$(shell_profile_path)"
  marker_begin="# >>> silo-migrate PATH >>>"
  marker_end="# <<< silo-migrate PATH <<<"

  if [ -f "$profile" ] && grep -Fq "$marker_begin" "$profile"; then
    return
  fi

  if [[ ":$PATH:" == *":$bin_dir:"* ]] && [ -z "$brew_ruby_bin" ]; then
    return
  fi

  if ! confirm "Add silo-migrate PATH setup to $profile?"; then
    return
  fi

  path_prefix="$bin_dir"
  if [ -n "$brew_ruby_bin" ]; then
    path_prefix="$brew_ruby_bin:$path_prefix"
  fi
  shellenv_line=""
  if command_exists brew; then
    shellenv_line="eval \"\$(brew shellenv)\""
  elif [ -x /opt/homebrew/bin/brew ]; then
    shellenv_line="eval \"\$(/opt/homebrew/bin/brew shellenv)\""
  elif [ -x /usr/local/bin/brew ]; then
    shellenv_line="eval \"\$(/usr/local/bin/brew shellenv)\""
  fi

  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] update $profile"
    return
  fi

  mkdir -p "$(dirname "$profile")"
  {
    printf '\n%s\n' "$marker_begin"
    [ -n "$shellenv_line" ] && printf '%s\n' "$shellenv_line"
    printf 'export PATH="%s:$PATH"\n' "$path_prefix"
    printf '%s\n' "$marker_end"
  } >> "$profile"
}

ensure_command() {
  command_exists "$1" || fail "$1 is required. Re-run with --install-deps or install it manually."
}

write_shim() {
  local name="$1"
  local shim="$bin_dir/$name"
  local escaped_dir
  escaped_dir="$(shell_quote "$install_dir")"

  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] write $shim"
    return
  fi

  cat > "$shim" <<SHIM
#!/usr/bin/env bash
set -euo pipefail
cd $escaped_dir
exec bundle exec ruby bin/$name "\$@"
SHIM
  chmod +x "$shim"
}

clone_or_update_checkout() {
  if [ "$dry_run" -eq 1 ]; then
    if [ -d "$install_dir/.git" ]; then
      run_cmd git -C "$install_dir" fetch origin "$branch"
      run_cmd git -C "$install_dir" checkout "$branch"
      run_cmd git -C "$install_dir" pull --ff-only origin "$branch"
    else
      run_cmd git clone --branch "$branch" "$repo" "$install_dir"
    fi
    return
  fi

  mkdir -p "$(dirname "$install_dir")"
  if [ -d "$install_dir/.git" ]; then
    log "Updating existing checkout at $install_dir..."
    git -C "$install_dir" fetch origin "$branch"
    git -C "$install_dir" checkout "$branch"
    git -C "$install_dir" pull --ff-only origin "$branch"
  elif [ -e "$install_dir" ]; then
    fail "$install_dir exists but is not a Git checkout. Move it away or pass --install-dir."
  else
    log "Cloning $repo into $install_dir..."
    git clone --branch "$branch" "$repo" "$install_dir"
  fi
}

run_doctor() {
  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] $bin_dir/silo-migrate doctor"
    return
  fi

  if "$bin_dir/silo-migrate" doctor; then
    return
  fi

  warn "silo-migrate doctor still reports actionable setup items."
}

ensure_host_dependencies
if [ "$dry_run" -eq 1 ] && [ "$install_deps" -eq 1 ]; then
  log "[dry-run] verify git and Ruby >= 3.1 after dependency installation"
else
  ensure_command git
  ensure_command ruby

  if ! ruby_ready; then
    fail "Ruby >= 3.1 is required. Re-run with --install-deps or install Ruby with rbenv, asdf, or Homebrew."
  fi
fi

install_bundler
install_oh_my_zsh

clone_or_update_checkout

log "Installing Ruby gems..."
if [ "$dry_run" -eq 1 ]; then
  run_cmd bundle install
else
  (cd "$install_dir" && bundle install)
fi

if [ "$dry_run" -eq 1 ]; then
  log "[dry-run] mkdir -p $bin_dir"
else
  mkdir -p "$bin_dir"
fi
write_shim silo-migrate
write_shim migration-tool
write_shim xml-to-sql
ensure_shell_path

log "[OK] Installed silo-migrate shims in $bin_dir"
if [[ ":$PATH:" != *":$bin_dir:"* ]]; then
  warn "$bin_dir is not on PATH."
  log "Add this to your shell profile: export PATH=\"$bin_dir:\$PATH\""
fi

run_doctor
