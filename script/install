#!/usr/bin/env bash
set -euo pipefail

yes_mode=0
install_deps=0
with_oh_my_zsh=0
skip_docker=0
dry_run=0
uninstall_mode=0
docker_source="auto"
shell_preset=""
zsh_theme=""
zsh_plugins=""
repo=""
branch=""
install_dir=""
bin_dir=""
brew_ruby_bin=""
sudocmd=()

usage() {
  cat <<'HELP'
Usage: script/install [options]

Installs silo-migrate from a Git-managed checkout and writes global shims.
This is the primary installer for macOS, Debian/Ubuntu, and Fedora/RHEL hosts.

Options:
  --yes                         non-interactive install; also enables --install-deps
  --install-deps                install missing host dependencies first
  --with-oh-my-zsh              install Oh My Zsh when dependencies are installed
  --shell-preset PRESET         configure curated shell add-ons: migration
  --zsh-theme THEME             zsh theme: robbyrussell or powerlevel10k
  --zsh-plugins LIST            comma-separated allowlisted zsh plugins
  --skip-docker                 do not install Docker host packages
  --docker-source SOURCE        Docker source: official, distro, or auto (default: auto)
  --bin-dir DIR                 write shims to DIR
  --install-dir DIR             clone/update the managed checkout at DIR
  --repo URL                    Git repository URL (default: HTTPS GitHub repo)
  --branch BRANCH               Git branch (default: main)
  --dry-run                     print commands without running them
  --uninstall                   remove shims, PATH block, and managed checkout
  -h, --help                    show this help

Environment overrides are still supported:
  SILO_MIGRATE_REPO, SILO_MIGRATE_BRANCH, SILO_MIGRATE_INSTALL_DIR,
  SILO_MIGRATE_BIN_DIR, XDG_DATA_HOME
HELP
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf '[WARN] %s\n' "$*" >&2
}

fail() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

confirm() {
  local prompt="$1"
  [ "$yes_mode" -eq 1 ] && return 0
  [ -t 0 ] || return 1
  local answer
  read -r -p "$prompt [y/N] " answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

shell_quote() {
  printf '%q' "$1"
}

print_command() {
  printf '+ '
  printf '%q ' "$@"
  printf '\n'
}

run_cmd() {
  if [ "$dry_run" -eq 1 ]; then
    print_command "$@"
    return 0
  fi
  "$@"
}

run_root_cmd() {
  if [ "$dry_run" -eq 1 ]; then
    if [ "${#sudocmd[@]}" -gt 0 ]; then
      printf '+ '
      printf '%q ' "${sudocmd[@]}"
      printf '%q ' "$@"
      printf '\n'
      return 0
    fi
    print_command "$@"
    return 0
  fi
  "${sudocmd[@]}" "$@"
}

run_root_shell() {
  local command="$1"
  if [ "$dry_run" -eq 1 ]; then
    if [ "${#sudocmd[@]}" -gt 0 ]; then
      printf '+ '
      printf '%q ' "${sudocmd[@]}"
      printf 'sh -c %q\n' "$command"
    else
      printf '+ sh -c %q\n' "$command"
    fi
    return 0
  fi
  "${sudocmd[@]}" sh -c "$command"
}

run_shell() {
  local command="$1"
  if [ "$dry_run" -eq 1 ]; then
    printf '+ sh -c %q\n' "$command"
    return 0
  fi
  sh -c "$command"
}

setup_sudo() {
  if [ "$(id -u)" -eq 0 ]; then
    sudocmd=()
  elif command_exists sudo; then
    sudocmd=(sudo)
  elif [ "$dry_run" -eq 1 ]; then
    sudocmd=(sudo)
  else
    return 1
  fi
}

detect_os_id() {
  local key="$1"
  if [ -r /etc/os-release ]; then
    . /etc/os-release
    case "$key" in
      id) printf '%s' "${ID:-}" ;;
      version_codename) printf '%s' "${VERSION_CODENAME:-}" ;;
      version_id) printf '%s' "${VERSION_ID:-}" ;;
      id_like) printf '%s' "${ID_LIKE:-}" ;;
    esac
  fi
}

ruby_ready() {
  command_exists ruby && ruby -e 'exit(Gem::Version.new(RUBY_VERSION) >= Gem::Version.new("3.1.0"))' >/dev/null 2>&1
}

prefer_homebrew_ruby() {
  command_exists brew || return 0
  local prefix
  prefix="$(brew --prefix ruby 2>/dev/null || true)"
  [ -n "$prefix" ] || return 0
  [ -x "$prefix/bin/ruby" ] || return 0
  brew_ruby_bin="$prefix/bin"
  export PATH="$brew_ruby_bin:$PATH"
}

default_bin_dir() {
  if [ "$(id -u)" -eq 0 ]; then
    printf '%s\n' "/usr/local/bin"
  else
    printf '%s\n' "${HOME:?HOME is required}/.local/bin"
  fi
}

default_install_dir() {
  local home_dir="${HOME:?HOME is required}"
  local data_home="${XDG_DATA_HOME:-$home_dir/.local/share}"
  printf '%s\n' "$data_home/silo-migrate/source"
}

parse_value_option() {
  local current="$1"
  local next="${2:-}"
  if [[ "$current" == *=* ]]; then
    printf '%s\n' "${current#*=}"
  else
    [ -n "$next" ] || fail "$current requires a value"
    printf '%s\n' "$next"
  fi
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --yes) yes_mode=1; install_deps=1 ;;
    --install-deps) install_deps=1 ;;
    --with-oh-my-zsh) with_oh_my_zsh=1 ;;
    --skip-docker) skip_docker=1 ;;
    --dry-run|--check-only) dry_run=1 ;;
    --uninstall) uninstall_mode=1 ;;
    --shell-preset|--shell-preset=*)
      shell_preset="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    --zsh-theme|--zsh-theme=*)
      zsh_theme="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    --zsh-plugins|--zsh-plugins=*)
      zsh_plugins="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    --docker-source|--docker-source=*)
      docker_source="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    --bin-dir|--bin-dir=*)
      bin_dir="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    --install-dir|--install-dir=*)
      install_dir="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    --repo|--repo=*)
      repo="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    --branch|--branch=*)
      branch="$(parse_value_option "$1" "${2:-}")"
      [[ "$1" == *=* ]] || shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *) fail "unknown option $1" ;;
  esac
  shift
done

case "$docker_source" in
  auto|official|distro) ;;
  *) fail "--docker-source must be official, distro, or auto" ;;
esac

case "$shell_preset" in
  ""|migration) ;;
  *) fail "--shell-preset must be migration" ;;
esac

case "$zsh_theme" in
  ""|robbyrussell|powerlevel10k) ;;
  *) fail "--zsh-theme must be robbyrussell or powerlevel10k" ;;
esac

if [ -n "$shell_preset" ] || [ -n "$zsh_theme" ] || [ -n "$zsh_plugins" ]; then
  install_deps=1
  with_oh_my_zsh=1
fi

if [ "$shell_preset" = "migration" ]; then
  zsh_theme="${zsh_theme:-robbyrussell}"
  zsh_plugins="${zsh_plugins:-git,zsh-autosuggestions,zsh-syntax-highlighting}"
fi

if [ -n "$zsh_plugins" ]; then
  normalized_zsh_plugins=""
  zsh_syntax_highlighting_requested=0
  for plugin in ${zsh_plugins//,/ }; do
    [ -n "$plugin" ] || continue
    case "$plugin" in
      git|docker|zsh-autosuggestions) ;;
      zsh-syntax-highlighting)
        zsh_syntax_highlighting_requested=1
        continue
        ;;
      *) fail "--zsh-plugins contains unsupported plugin: $plugin" ;;
    esac
    case " $normalized_zsh_plugins " in
      *" $plugin "*) ;;
      *) normalized_zsh_plugins="$normalized_zsh_plugins $plugin" ;;
    esac
  done
  if [ "$zsh_syntax_highlighting_requested" -eq 1 ]; then
    normalized_zsh_plugins="$normalized_zsh_plugins zsh-syntax-highlighting"
  fi
  zsh_plugins="${normalized_zsh_plugins# }"
fi

repo="${repo:-${SILO_MIGRATE_REPO:-https://github.com/RubenOussoren/silo-migrate.git}}"
branch="${branch:-${SILO_MIGRATE_BRANCH:-main}}"
install_dir="${install_dir:-${SILO_MIGRATE_INSTALL_DIR:-$(default_install_dir)}}"
bin_dir="${bin_dir:-${SILO_MIGRATE_BIN_DIR:-$(default_bin_dir)}}"

path_marker_begin() {
  printf '%s\n' "# >>> silo-migrate PATH >>>"
}

path_marker_end() {
  printf '%s\n' "# <<< silo-migrate PATH <<<"
}

zsh_preset_marker_begin() {
  printf '%s\n' "# >>> silo-migrate zsh preset >>>"
}

zsh_preset_marker_end() {
  printf '%s\n' "# <<< silo-migrate zsh preset <<<"
}

oh_my_zsh_dir() {
  printf '%s\n' "${ZSH:-${HOME:?HOME is required}/.oh-my-zsh}"
}

zsh_custom_dir() {
  printf '%s\n' "${ZSH_CUSTOM:-$(oh_my_zsh_dir)/custom}"
}

oh_my_zsh_entrypoint() {
  printf '%s\n' "$(oh_my_zsh_dir)/oh-my-zsh.sh"
}

oh_my_zsh_installed() {
  [ -f "$(oh_my_zsh_entrypoint)" ]
}

manual_oh_my_zsh_cleanup_hint() {
  local zsh_dir="$1"
  printf 'Move it away manually, then rerun. Example: mv %q %q\n' \
    "$zsh_dir" "${zsh_dir}.broken-\$(date +%Y%m%d%H%M%S)"
}

zsh_shell_path() {
  if command_exists zsh; then
    command -v zsh
  elif [ -x /usr/bin/zsh ]; then
    printf '%s\n' /usr/bin/zsh
  elif [ -x /bin/zsh ]; then
    printf '%s\n' /bin/zsh
  fi
}

zsh_plugin_enabled() {
  local wanted="$1"
  case " $zsh_plugins " in
    *" $wanted "*) return 0 ;;
    *) return 1 ;;
  esac
}

install_homebrew() {
  if command_exists brew; then
    return
  fi

  if ! confirm "Install Homebrew using the official installer?"; then
    warn "Homebrew is missing. Install it from https://brew.sh/ or install git, Ruby >= 3.1, and Docker manually."
    return
  fi

  command_exists curl || fail "curl is required to install Homebrew."
  run_shell '/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'

  for brew_path in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [ -x "$brew_path" ]; then
      eval "$("$brew_path" shellenv)"
      return
    fi
  done
}

install_macos_deps() {
  install_homebrew
  command_exists brew || return 0

  local formulas=()
  command_exists git || formulas+=(git)
  ruby_ready || formulas+=(ruby)
  command_exists pkg-config || formulas+=(pkg-config)
  command_exists zsh || formulas+=(zsh)

  if [ "${#formulas[@]}" -gt 0 ]; then
    log "Installing Homebrew packages: ${formulas[*]}"
    run_cmd brew install "${formulas[@]}"
  fi

  if [ "$skip_docker" -eq 0 ] && ! command_exists docker; then
    if confirm "Install Docker Desktop with Homebrew cask?"; then
      run_cmd brew install --cask docker
      warn "Open Docker Desktop once after installation so the daemon starts."
    else
      warn "Docker is missing. Install Docker Desktop before running migration containers."
    fi
  fi

  prefer_homebrew_ruby
}

docker_conflicts_installed() {
  command_exists dpkg || return 1
  local pkg
  for pkg in docker.io docker-doc docker-compose podman-docker containerd runc; do
    if dpkg -s "$pkg" >/dev/null 2>&1; then
      return 0
    fi
  done
  return 1
}

install_apt_base_packages() {
  local packages=(git ruby ruby-dev build-essential pkg-config zlib1g-dev libsqlite3-dev zsh curl ca-certificates gnupg)
  log "Installing Debian/Ubuntu base packages: ${packages[*]}"
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before --install-deps."
  run_root_cmd apt-get update
  run_root_cmd apt-get install -y "${packages[@]}"
}

install_apt_distro_docker() {
  local packages=(docker.io docker-compose-plugin)
  log "Installing Debian/Ubuntu distro Docker packages: ${packages[*]}"
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before installing Docker."
  run_root_cmd apt-get install -y "${packages[@]}"
}

install_apt_official_docker() {
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before installing Docker."

  local id codename
  id="$(detect_os_id id)"
  codename="$(detect_os_id version_codename)"
  if [[ "$id" != "debian" && "$id" != "ubuntu" ]]; then
    warn "Docker's apt repository supports Debian/Ubuntu here; falling back to distro packages."
    install_apt_distro_docker
    return
  fi
  [ -n "$codename" ] || fail "Could not detect Debian/Ubuntu codename for Docker's official apt repository."

  if docker_conflicts_installed; then
    if confirm "Remove conflicting distro Docker packages before installing Docker Engine from Docker's apt repository?"; then
      run_root_cmd apt-get remove -y docker.io docker-doc docker-compose podman-docker containerd runc
    else
      warn "Skipping official Docker repository because conflicting packages are installed."
      return
    fi
  fi

  log "Installing Docker Engine from Docker's official apt repository..."
  run_root_cmd install -m 0755 -d /etc/apt/keyrings
  run_root_shell "curl -fsSL https://download.docker.com/linux/$id/gpg -o /etc/apt/keyrings/docker.asc"
  run_root_cmd chmod a+r /etc/apt/keyrings/docker.asc
  run_root_shell "echo \"deb [arch=\$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/$id $codename stable\" > /etc/apt/sources.list.d/docker.list"
  run_root_cmd apt-get update
  run_root_cmd apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
}

install_apt_packages() {
  install_apt_base_packages
  [ "$skip_docker" -eq 1 ] && return

  if command_exists docker; then
    return
  fi

  case "$docker_source" in
    distro) install_apt_distro_docker ;;
    official|auto) install_apt_official_docker ;;
  esac
}

install_dnf_base_packages() {
  local packages=(git ruby ruby-devel gcc gcc-c++ make pkgconf-pkg-config zlib-devel sqlite-devel zsh curl ca-certificates)
  log "Installing Fedora/RHEL base packages: ${packages[*]}"
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before --install-deps."
  run_root_cmd dnf install -y "${packages[@]}"
}

install_dnf_distro_docker() {
  local packages=(docker docker-compose-plugin)
  log "Installing distro Docker packages with dnf: ${packages[*]}"
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before installing Docker."
  run_root_cmd dnf install -y "${packages[@]}"
}

install_dnf_official_docker() {
  setup_sudo || fail "sudo is missing. Re-run as root or install sudo before installing Docker."

  local id id_like repo_os
  id="$(detect_os_id id)"
  id_like="$(detect_os_id id_like)"
  case " $id $id_like " in
    *" fedora "*) repo_os="fedora" ;;
    *" rhel "*|*" centos "*|*" rocky "*|*" almalinux "*) repo_os="centos" ;;
    *)
      warn "Docker's dnf repository is not configured for this distribution. Install Docker Engine manually from https://docs.docker.com/engine/install/."
      return
      ;;
  esac

  log "Installing Docker Engine from Docker's official dnf repository..."
  run_root_cmd dnf install -y dnf-plugins-core
  run_root_cmd dnf config-manager --add-repo "https://download.docker.com/linux/$repo_os/docker-ce.repo"
  run_root_cmd dnf install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
}

install_dnf_packages() {
  install_dnf_base_packages
  [ "$skip_docker" -eq 1 ] && return

  if command_exists docker; then
    return
  fi

  case "$docker_source" in
    distro) install_dnf_distro_docker ;;
    official|auto) install_dnf_official_docker ;;
  esac
}

enable_docker_service() {
  [ "$skip_docker" -eq 0 ] || return 0
  command_exists systemctl || return 0
  command_exists docker || [ "$dry_run" -eq 1 ] || return 0

  if confirm "Enable and start the Docker service?"; then
    setup_sudo || fail "sudo is missing. Re-run as root or start Docker manually."
    run_root_cmd systemctl enable --now docker
  else
    warn "Start Docker manually before running migration containers."
  fi
}

install_linux_deps() {
  if command_exists apt-get; then
    install_apt_packages
  elif command_exists dnf; then
    install_dnf_packages
  else
    warn "Unsupported Linux package manager. Install git, Ruby >= 3.1, Bundler, Docker Compose v2, and zsh manually."
  fi
  enable_docker_service
}

install_host_dependencies() {
  case "$(uname -s)" in
    Darwin) install_macos_deps ;;
    Linux) install_linux_deps ;;
    *) warn "Unsupported OS. Install git, Ruby >= 3.1, Bundler, Docker Compose v2, and zsh manually." ;;
  esac
}

ensure_host_dependencies() {
  if [ "$install_deps" -eq 1 ]; then
    install_host_dependencies
  elif ! command_exists git || ! ruby_ready; then
    if confirm "Install missing host dependencies now?"; then
      install_host_dependencies
    else
      fail "git and Ruby >= 3.1 are required. Re-run with --install-deps or install them manually."
    fi
  fi
}

install_bundler() {
  if [ "$dry_run" -eq 1 ] && [ "$install_deps" -eq 1 ]; then
    log "[dry-run] gem install bundler if missing"
    return
  fi

  command_exists bundle && return

  log "Installing Bundler..."
  run_cmd gem install bundler
}

install_oh_my_zsh() {
  [ "$install_deps" -eq 1 ] || return

  local zsh_dir entrypoint backup timestamp
  zsh_dir="$(oh_my_zsh_dir)"
  entrypoint="$(oh_my_zsh_entrypoint)"

  oh_my_zsh_installed && return

  if [ -d "$zsh_dir" ]; then
    warn "Oh My Zsh directory exists at $zsh_dir, but $entrypoint is missing; it looks incomplete."
    if [ "$shell_preset" = "migration" ]; then
      timestamp="$(date +%Y%m%d%H%M%S)"
      backup="${zsh_dir}.broken-${timestamp}"
      while [ "$dry_run" -eq 0 ] && [ -e "$backup" ]; do
        timestamp="$(date +%Y%m%d%H%M%S)-$$"
        backup="${zsh_dir}.broken-${timestamp}"
      done
      log "Moving incomplete Oh My Zsh directory to $backup before reinstalling."
      run_cmd mv "$zsh_dir" "$backup"
    elif [ "$with_oh_my_zsh" -eq 1 ]; then
      fail "Refusing to overwrite incomplete Oh My Zsh directory at $zsh_dir. $(manual_oh_my_zsh_cleanup_hint "$zsh_dir")"
    else
      warn "Skipping Oh My Zsh install. $(manual_oh_my_zsh_cleanup_hint "$zsh_dir")"
      return
    fi
  fi

  if [ "$with_oh_my_zsh" -ne 1 ] && [ "$yes_mode" -eq 1 ]; then
    log "Skipping Oh My Zsh; pass --with-oh-my-zsh to install it non-interactively."
    return
  fi

  if [ "$with_oh_my_zsh" -eq 1 ] || confirm "Install Oh My Zsh?"; then
    if ! command_exists curl && { [ "$dry_run" -eq 0 ] || [ "$install_deps" -eq 0 ]; }; then
      fail "curl is required to install Oh My Zsh."
    fi
    if [ -n "$shell_preset" ]; then
      run_shell 'RUNZSH=no CHSH=no KEEP_ZSHRC=yes sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended'
    else
      run_shell 'RUNZSH=no CHSH=no sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended'
    fi
  fi
}

shell_profile_path() {
  case "${SHELL:-}" in
    */bash) printf '%s\n' "${HOME:?HOME is required}/.bashrc" ;;
    *) printf '%s\n' "${HOME:?HOME is required}/.zshrc" ;;
  esac
}

ensure_shell_path() {
  local profile marker_begin marker_end path_prefix shellenv_line
  profile="$(shell_profile_path)"
  marker_begin="$(path_marker_begin)"
  marker_end="$(path_marker_end)"

  if [ -f "$profile" ] && grep -Fq "$marker_begin" "$profile"; then
    return
  fi

  if [[ ":$PATH:" == *":$bin_dir:"* ]] && [ -z "$brew_ruby_bin" ]; then
    return
  fi

  if ! confirm "Add silo-migrate PATH setup to $profile?"; then
    return
  fi

  path_prefix="$bin_dir"
  if [ -n "$brew_ruby_bin" ]; then
    path_prefix="$brew_ruby_bin:$path_prefix"
  fi
  shellenv_line=""
  if command_exists brew; then
    shellenv_line="eval \"\$(brew shellenv)\""
  elif [ -x /opt/homebrew/bin/brew ]; then
    shellenv_line="eval \"\$(/opt/homebrew/bin/brew shellenv)\""
  elif [ -x /usr/local/bin/brew ]; then
    shellenv_line="eval \"\$(/usr/local/bin/brew shellenv)\""
  fi

  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] update $profile"
    return
  fi

  mkdir -p "$(dirname "$profile")"
  {
    printf '\n%s\n' "$marker_begin"
    [ -n "$shellenv_line" ] && printf '%s\n' "$shellenv_line"
    printf 'export PATH="%s:$PATH"\n' "$path_prefix"
    printf '%s\n' "$marker_end"
  } >> "$profile"
}

remove_shell_path_block() {
  local profile marker_begin marker_end tmp
  profile="$(shell_profile_path)"
  marker_begin="$(path_marker_begin)"
  marker_end="$(path_marker_end)"

  if [ ! -f "$profile" ] || ! grep -Fq "$marker_begin" "$profile"; then
    log "No silo-migrate PATH block found in $profile"
    return 0
  fi

  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] remove silo-migrate PATH block from $profile"
    return 0
  fi

  tmp="${profile}.silo-migrate-uninstall.$$"
  awk -v begin="$marker_begin" -v end="$marker_end" '
    $0 == begin { skipping = 1; next }
    $0 == end { skipping = 0; next }
    !skipping { print }
  ' "$profile" > "$tmp"
  mv "$tmp" "$profile"
  log "Removed silo-migrate PATH block from $profile"
}

replace_managed_block() {
  local file="$1"
  local begin="$2"
  local end="$3"
  local body="$4"
  local tmp

  mkdir -p "$(dirname "$file")"
  tmp="${file}.silo-migrate.$$"
  if [ -f "$file" ]; then
    awk -v begin="$begin" -v end="$end" '
      $0 == begin { skipping = 1; next }
      $0 == end { skipping = 0; next }
      !skipping { print }
    ' "$file" > "$tmp"
  else
    : > "$tmp"
  fi
  {
    printf '\n%s\n' "$begin"
    printf '%s\n' "$body"
    printf '%s\n' "$end"
  } >> "$tmp"
  mv "$tmp" "$file"
}

remove_managed_block() {
  local file="$1"
  local begin="$2"
  local end="$3"
  local description="$4"
  local tmp

  if [ ! -f "$file" ] || ! grep -Fq "$begin" "$file"; then
    log "No $description block found in $file"
    return 0
  fi

  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] remove $description block from $file"
    return 0
  fi

  tmp="${file}.silo-migrate.$$"
  awk -v begin="$begin" -v end="$end" '
    $0 == begin { skipping = 1; next }
    $0 == end { skipping = 0; next }
    !skipping { print }
  ' "$file" > "$tmp"
  mv "$tmp" "$file"
  log "Removed $description block from $file"
}

install_or_update_zsh_addon() {
  local target="$1"
  local url="$2"
  local marker="$target/.silo-migrate-installed"

  if [ -d "$target/.git" ]; then
    log "Updating zsh add-on at $target..."
    run_cmd git -C "$target" pull --ff-only
    return
  fi

  if [ -e "$target" ]; then
    if [ ! -f "$marker" ]; then
      fail "$target exists but is not a Git checkout. Move it away manually or remove it before rerunning."
    fi

    log "Replacing incomplete installer-managed zsh add-on at $target..."
    run_cmd rm -rf "$target"
  fi

  log "Installing zsh add-on $url into $target..."
  run_cmd mkdir -p "$(dirname "$target")"
  run_cmd git clone --depth 1 "$url" "$target"
  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] write $marker"
  else
    printf '%s\n' "installed by script/install --shell-preset" > "$marker"
  fi
}

remove_owned_zsh_addon() {
  local target="$1"
  local marker="$target/.silo-migrate-installed"

  if [ ! -e "$target" ]; then
    return 0
  fi

  if [ ! -f "$marker" ]; then
    log "Skipping $target because it was not installed by silo-migrate."
    return 0
  fi

  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] remove zsh add-on $target"
    return 0
  fi

  rm -rf "$target"
  log "Removed zsh add-on $target"
}

configure_zsh_preset() {
  [ -n "$shell_preset" ] || return 0

  local custom_dir profile plugin_array theme_value body
  custom_dir="$(zsh_custom_dir)"
  profile="${HOME:?HOME is required}/.zshrc"

  if zsh_plugin_enabled zsh-autosuggestions; then
    install_or_update_zsh_addon "$custom_dir/plugins/zsh-autosuggestions" "https://github.com/zsh-users/zsh-autosuggestions.git"
  fi
  if zsh_plugin_enabled zsh-syntax-highlighting; then
    install_or_update_zsh_addon "$custom_dir/plugins/zsh-syntax-highlighting" "https://github.com/zsh-users/zsh-syntax-highlighting.git"
  fi
  if [ "$zsh_theme" = "powerlevel10k" ]; then
    install_or_update_zsh_addon "$custom_dir/themes/powerlevel10k" "https://github.com/romkatv/powerlevel10k.git"
    theme_value="powerlevel10k/powerlevel10k"
  else
    theme_value="$zsh_theme"
  fi

  plugin_array="${zsh_plugins:-git}"
  body="$(
    printf '%s\n' 'export ZSH="${ZSH:-$HOME/.oh-my-zsh}"'
    printf 'ZSH_THEME="%s"\n' "$theme_value"
    printf 'plugins=(%s)\n' "$plugin_array"
    printf '\n'
    printf '%s\n' '# Keep credential exports out of history/autosuggestions. Prefix sensitive'
    printf '%s\n' '# one-off commands with a leading space for HIST_IGNORE_SPACE.'
    printf '%s\n' 'setopt HIST_IGNORE_SPACE HIST_NO_STORE HIST_REDUCE_BLANKS'
    printf '%s\n' 'HISTFILE="${HISTFILE:-$HOME/.zsh_history}"'
    printf '%s\n' 'HISTSIZE="${HISTSIZE:-50000}"'
    printf '%s\n' 'SAVEHIST="${SAVEHIST:-50000}"'
    printf '%s\n' 'ZSH_AUTOSUGGEST_STRATEGY=(completion)'
    printf '%s\n' 'ZSH_AUTOSUGGEST_HISTORY_IGNORE="(export AWS_*|AWS_ACCESS_KEY_ID=*|AWS_SECRET_ACCESS_KEY=*|AWS_SESSION_TOKEN=*|aws configure export-credentials*)"'
    printf '\n'
    printf '%s\n' 'source "$ZSH/oh-my-zsh.sh"'
  )"

  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] update zsh preset block in $profile"
    printf '%s\n' "$body"
    return 0
  fi

  replace_managed_block "$profile" "$(zsh_preset_marker_begin)" "$(zsh_preset_marker_end)" "$body"
  log "Updated zsh preset block in $profile"
}

ensure_zsh_login_shell() {
  [ "$with_oh_my_zsh" -eq 1 ] || return 0

  case "${SHELL:-}" in
    */zsh) return 0 ;;
  esac

  local zsh_path user
  zsh_path="$(zsh_shell_path)"
  if [ -z "$zsh_path" ]; then
    warn "zsh was not found on PATH. Install zsh, then run: chsh -s /usr/bin/zsh $(id -un)"
    return 0
  fi

  if ! command_exists chsh && [ "$dry_run" -eq 0 ]; then
    warn "chsh is unavailable. Set zsh as the login shell manually: chsh -s $zsh_path $(id -un)"
    return 0
  fi

  user="$(id -un)"
  if [ "$(id -u)" -ne 0 ] && [ ! -t 0 ] && [ "$dry_run" -eq 0 ]; then
    warn "Set zsh as the login shell manually: chsh -s $zsh_path $user"
    return 0
  fi

  log "Setting login shell for $user to $zsh_path..."
  run_cmd chsh -s "$zsh_path" "$user" || warn "Could not set login shell automatically. Run manually: chsh -s $zsh_path $user"
}

remove_zsh_preset() {
  local custom_dir profile
  custom_dir="$(zsh_custom_dir)"
  profile="${HOME:?HOME is required}/.zshrc"

  remove_managed_block "$profile" "$(zsh_preset_marker_begin)" "$(zsh_preset_marker_end)" "silo-migrate zsh preset"
  remove_owned_zsh_addon "$custom_dir/plugins/zsh-autosuggestions"
  remove_owned_zsh_addon "$custom_dir/plugins/zsh-syntax-highlighting"
  remove_owned_zsh_addon "$custom_dir/themes/powerlevel10k"
}

ensure_command() {
  command_exists "$1" || fail "$1 is required. Re-run with --install-deps or install it manually."
}

write_shim() {
  local name="$1"
  local shim="$bin_dir/$name"
  local escaped_dir
  escaped_dir="$(shell_quote "$install_dir")"

  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] write $shim"
    return
  fi

  cat > "$shim" <<SHIM
#!/usr/bin/env bash
set -euo pipefail
cd $escaped_dir
exec bundle exec ruby bin/$name "\$@"
SHIM
  chmod +x "$shim"
}

shim_owned_by_install() {
  local name="$1"
  local shim="$bin_dir/$name"
  local escaped_dir
  escaped_dir="$(shell_quote "$install_dir")"

  [ -f "$shim" ] || return 1
  grep -Fq "cd $escaped_dir" "$shim" && grep -Fq "exec bundle exec ruby bin/$name" "$shim"
}

remove_shim() {
  local name="$1"
  local shim="$bin_dir/$name"

  if [ ! -e "$shim" ]; then
    log "No shim found at $shim"
    return 0
  fi

  if ! shim_owned_by_install "$name"; then
    warn "Skipping $shim because it does not look like a silo-migrate installer shim."
    return 0
  fi

  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] remove $shim"
    return 0
  fi

  rm -f "$shim"
  log "Removed $shim"
}

managed_checkout() {
  [ -d "$install_dir/.git" ] &&
    [ -f "$install_dir/script/install" ] &&
    [ -f "$install_dir/bin/silo-migrate" ] &&
    [ -f "$install_dir/silo-migrate.gemspec" ]
}

remove_managed_checkout() {
  if [ ! -e "$install_dir" ]; then
    log "No managed checkout found at $install_dir"
    return 0
  fi

  if ! managed_checkout; then
    fail "$install_dir does not look like a managed silo-migrate checkout. Refusing to remove it."
  fi

  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] remove managed checkout $install_dir"
    return 0
  fi

  rm -rf "$install_dir"
  log "Removed managed checkout $install_dir"
}

uninstall_silo_migrate() {
  log "Uninstalling silo-migrate CLI artifacts..."
  remove_shim silo-migrate
  remove_shim migration-tool
  remove_shim xml-to-sql
  remove_shell_path_block
  remove_zsh_preset
  remove_managed_checkout
  log "[OK] Uninstalled silo-migrate CLI artifacts."
  log "Migration projects, Docker volumes, Ruby gems, Homebrew, Docker, and OS packages were not removed."
}

clone_or_update_checkout() {
  if [ "$dry_run" -eq 1 ]; then
    if [ -d "$install_dir/.git" ]; then
      run_cmd git -C "$install_dir" fetch origin "$branch"
      run_cmd git -C "$install_dir" checkout "$branch"
      run_cmd git -C "$install_dir" pull --ff-only origin "$branch"
    else
      run_cmd git clone --branch "$branch" "$repo" "$install_dir"
    fi
    return
  fi

  mkdir -p "$(dirname "$install_dir")"
  if [ -d "$install_dir/.git" ]; then
    log "Updating existing checkout at $install_dir..."
    git -C "$install_dir" fetch origin "$branch"
    git -C "$install_dir" checkout "$branch"
    git -C "$install_dir" pull --ff-only origin "$branch"
  elif [ -e "$install_dir" ]; then
    fail "$install_dir exists but is not a Git checkout. Move it away or pass --install-dir."
  else
    log "Cloning $repo into $install_dir..."
    git clone --branch "$branch" "$repo" "$install_dir"
  fi
}

run_doctor() {
  if [ "$dry_run" -eq 1 ]; then
    log "[dry-run] $bin_dir/silo-migrate doctor"
    return
  fi

  if "$bin_dir/silo-migrate" doctor; then
    return
  fi

  warn "silo-migrate doctor still reports actionable setup items."
}

if [ "$uninstall_mode" -eq 1 ]; then
  uninstall_silo_migrate
  exit 0
fi

ensure_host_dependencies
if [ "$dry_run" -eq 1 ] && [ "$install_deps" -eq 1 ]; then
  log "[dry-run] verify git and Ruby >= 3.1 after dependency installation"
else
  ensure_command git
  ensure_command ruby

  if ! ruby_ready; then
    fail "Ruby >= 3.1 is required. Re-run with --install-deps or install Ruby with rbenv, asdf, or Homebrew."
  fi
fi

install_bundler
install_oh_my_zsh
configure_zsh_preset
ensure_zsh_login_shell

clone_or_update_checkout

log "Installing Ruby gems..."
if [ "$dry_run" -eq 1 ]; then
  run_cmd bundle install
else
  (cd "$install_dir" && bundle install)
fi

if [ "$dry_run" -eq 1 ]; then
  log "[dry-run] mkdir -p $bin_dir"
else
  mkdir -p "$bin_dir"
fi
write_shim silo-migrate
write_shim migration-tool
write_shim xml-to-sql
ensure_shell_path

log "[OK] Installed silo-migrate shims in $bin_dir"
if [[ ":$PATH:" != *":$bin_dir:"* ]]; then
  warn "$bin_dir is not on PATH."
  log "Add this to your shell profile: export PATH=\"$bin_dir:\$PATH\""
fi

run_doctor
